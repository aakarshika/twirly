# pnpm config — hoist Capacitor packages into the repo-root node_modules/.
# This is required because the iOS Podfile and Android gradle files walk
# `../node_modules/@capacitor/*` from the native project directories, which
# resolves to <repo>/node_modules/. Without this hoist, pnpm would isolate
# Capacitor packages inside apps/web/node_modules/ and the native builds
# would fail to find them.
#
# Also makes `npx cap` discoverable at root (node_modules/.bin/cap).
public-hoist-pattern[]=@capacitor/*
