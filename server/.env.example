# Database — local Postgres started by `make dev` (docker-compose.yml maps host 7432 → container 5432).
DATABASE_URL=postgresql://twirly:twirly@localhost:7432/twirly

# Better Auth (32+ bytes; generate via `openssl rand -base64 48`)
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-or-longer-random-string
BETTER_AUTH_URL=http://localhost:8734

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend) — optional
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Server
PORT=8734
NODE_ENV=development
FRONTEND_URL=http://localhost:5734

# Storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
