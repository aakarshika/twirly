{
  "name": "twirly",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "web:dev": "vite --mode development",
    "web:stage": "vite --mode staging",
    "web:prod": "vite --mode production",
    "web:build": "vite build --mode development",
    "web:build:stage": "vite build --mode staging",
    "web:build:prod": "vite build --mode production",
    "web:preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,jsx}\"",
    "cap:sync": "npx cap sync",
    "xcode:clean": "cd ios/App && xcodebuild clean && cd ../..",
    "ios:clean": "npm run xcode:clean && npm run web:build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:dev": "npm run xcode:clean && npm run web:build && npx cap sync ios && npm run ios:open",
    "ios:stage": "npm run xcode:clean && npm run web:build:stage && npx cap sync ios && npm run ios:open",
    "ios:prod": "npm run xcode:clean && npm run web:build:prod && npx cap sync ios && npm run ios:open",
    "android:dev": "npm run web:build && npx cap sync android && npx cap open android",
    "android:stage": "npm run web:build:stage && npx cap sync android && npx cap open android",
    "android:prod": "npm run web:build:prod && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@heroicons/react": "^2.2.0",
    "@sentry/react": "^9.17.0",
    "@sentry/tracing": "^7.120.3",
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.8.4",
    "chart.js": "^4.4.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "framer-motion": "^12.12.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.487.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-infinite-scroll-component": "^6.1.0",
    "react-intersection-observer": "^9.16.0",
    "react-mentions": "^4.4.10",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.5.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "supabase": "^2.22.12",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "terser": "^5.39.0",
    "vite": "^5.0.8"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
